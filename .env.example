# Copy to .env and fill in. Every var here has a safe default — the service
# starts and serves a correct handover even with this file empty.
#
#   cp .env.example .env
#   npm install && npm run dev

# --- Server ----------------------------------------------------------------
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info        # pino level: trace | debug | info | warn | error | fatal

# --- Data ------------------------------------------------------------------
# Where events.json and night-logs.md live. Defaults to ./data in the repo.
# DATA_DIR=/absolute/path/to/data

# --- LLM (Anthropic) -------------------------------------------------------
# Optional. If unset or LLM_ENABLED=false, the night-log extractor falls back
# to a deterministic hand-written extractor that knows the demo log shape.
# The handover is still grounded — every line still cites its source.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
LLM_ENABLED=true
